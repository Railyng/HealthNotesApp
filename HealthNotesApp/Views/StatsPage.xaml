<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HealthNotesApp.Views.StatsPage">

    <VerticalStackLayout Padding="20" Spacing="20">

        <Label Text="📊 Estadísticas"
               FontSize="26"
               HorizontalOptions="Center"/>

        <Label Text="{Binding TotalHabits, StringFormat='Total de hábitos: {0}'}"
               FontSize="18"/>

        <Label Text="{Binding CompletionRate, StringFormat='Cumplimiento: {0}%'}"
               FontSize="18"/>
        
        <Label Text="📈 Gráfico próximamente"
               HorizontalOptions="Center"
               FontSize="16"/>

    </VerticalStackLayout>

</ContentPage>