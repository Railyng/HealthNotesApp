<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HealthNotesApp.Views.AddHabitPage"
             Title="AddHabitPage">
    <VerticalStackLayout Padding="20">

        <Label Text="Nuevo Hábito" FontSize="24" />

        <Entry Placeholder="Nombre del hábito"
               Text="{Binding Name}" />

        <Entry Placeholder="Meta diaria"
               Keyboard="Numeric"
               Text="{Binding Goal}" />

        <Button Text="Guardar"
                Command="{Binding SaveCommand}" />

    </VerticalStackLayout>
</ContentPage>