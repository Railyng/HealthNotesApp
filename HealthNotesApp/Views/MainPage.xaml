<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HealthNotesApp.Views.MainPage">

    <VerticalStackLayout Padding="20" Spacing="20">

        <Label Text="HealthNotes App"
               FontSize="24"
               HorizontalOptions="Center"/>

        <!-- LISTA DE HÁBITOS -->
        <CollectionView ItemsSource="{Binding Habits}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="#1E1E1E"
                           CornerRadius="10"
                           Padding="10"
                           Margin="0,5">

                        <VerticalStackLayout>
                            <Label Text="{Binding Name}"
                                   FontSize="18"
                                   TextColor="White"/>

                            <Label Text="{Binding Goal, StringFormat='Meta: {0}'}"
                                   TextColor="LightGray"/>

                            <Label Text="{Binding Progress, StringFormat='Progreso: {0}'}"
                                   TextColor="LightGray"/>
                        </VerticalStackLayout>

                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <Button Text="Agregar hábito"
                Command="{Binding GoToAddHabitCommand}" />

    </VerticalStackLayout>

</ContentPage>