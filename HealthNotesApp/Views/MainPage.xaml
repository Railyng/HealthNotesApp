<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HealthNotesApp.MainPage">

    <VerticalStackLayout Padding="20">

        <Label Text="HealthNotes App"
               FontSize="24"
               HorizontalOptions="Center" />

        <CollectionView ItemsSource="{Binding Habits}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5" Padding="10">
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" FontSize="18"/>
                            <Label Text="Meta: {Binding Goal}"/>
                            <Label Text="Progreso: {Binding Progress}"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="Agregar hábito"
                Command="{Binding AddHabitCommand}" />

    </VerticalStackLayout>
</ContentPage>